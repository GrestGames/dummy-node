{
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules"],
  "compilerOptions": {
    "experimentalDecorators": true,
    "outDir": "dist",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "noImplicitAny": true,
    "noImplicitReturns": true,
    "noImplicitThis": true,
    "noUnusedLocals": true,
    "noUnusedParameters": false,
    "target": "es6",
    "lib": ["esnext"]
  }
}
